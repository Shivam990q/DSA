{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecondBrainManifest",
  "type": "object",
  "required": [
    "generated_at",
    "stats",
    "documents"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "stats": {
      "type": "object"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "title",
          "codex"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "codex": {
            "type": "string"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}