{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KnowledgeGraph",
  "type": "object",
  "required": [
    "nodes",
    "edges"
  ],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type"
        ]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source",
          "target",
          "type"
        ]
      }
    }
  }
}